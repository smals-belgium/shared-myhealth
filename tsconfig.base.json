{
  "compilerOptions": {
    "baseUrl": ".",
    "declarationMap": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022", "dom", "dom.iterable"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@myhealth/source"],
    "paths": {
      "@myhealth/design-kit": ["./packages/design-kit/dist"],
      "@myhealth/vitals-ng": ["./packages/vitals-ng/src/index.ts"],
      "@myhealth/vitals-ng/button": [
        "./packages/vitals-ng/button/src/index.ts"
      ],
      "@myhealth/vitals-ng/checkbox": [
        "./packages/vitals-ng/checkbox/src/index.ts"
      ],
      "@myhealth/vitals-ng/radio": ["./packages/vitals-ng/radio/src/index.ts"]
    }
  }
}
