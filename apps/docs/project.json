{
  "name": "docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/docs/src",
  "projectType": "application",
  "tags": ["type:app", "scope:docs"],
  "implicitDependencies": ["vitals"],
  "targets": {
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run clean",
        "cwd": "apps/docs"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^bundle"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "npm run build",
        "cwd": "apps/docs"
      }
    },
    "watch-vitals": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "npx nx watch --projects vitals --includeDependencies -- npx nx run vitals:bundle"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "continuous": true,
      "dependsOn": ["^bundle", "watch-vitals"],
      "options": {
        "command": "npm run serve",
        "cwd": "apps/docs"
      }
    }
  }
}
