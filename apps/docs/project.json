{
  "name": "docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/docs/src",
  "projectType": "application",
  "tags": ["type:app", "scope:docs"],
  "targets": {
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run clean",
        "cwd": "apps/docs"
      }
    },
    "build": {
      "dependsOn": [
        {
          "projects": ["@myhealth/design-kit"],
          "target": "bundle"
        },
        {
          "projects": ["@myhealth/design-kit"],
          "target": "generate-manifest"
        }
      ],
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "npm run build",
        "cwd": "apps/docs"
      }
    },
    "serve": {
      "dependsOn": [
        {
          "projects": ["@myhealth/design-kit"],
          "target": "bundle"
        },
        {
          "projects": ["@myhealth/design-kit"],
          "target": "generate-manifest"
        }
      ],
      "executor": "nx:run-commands",
      "options": {
        "parallel": true,
        "commands": [
          {
            "command": "cd packages/design-kit && npx vite build --watch",
            "prefix": "[design-kit:build]"
          },
          {
            "command": "cd packages/design-kit && npx cem analyze --watch",
            "prefix": "[design-kit:manifest]"
          },
          {
            "command": "cd apps/docs && npm run serve",
            "prefix": "[docs]"
          }
        ]
      }
    }
  }
}
