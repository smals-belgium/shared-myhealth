---
layout: layout.njk
title: Introduction
---

<div class="page-header">
  <h1>Design Kit Documentation</h1>
  <p class="page-subtitle">
    Auto-generated reference for all components in
    <code>packages/vitals/components/src</code>.
  </p>
  <p>Generated at: {{ components.generatedAt }}</p>
</div>
<section aria-labelledby="components-heading">
  <h2 id="components-heading">Components</h2>
  <div class="component-list">
    {% for component in components.components %}
      <a href="/components/{{ component.slug }}/" class="component-entry">
        <span class="component-entry-name">{{ component.name }}</span>
        {% if component.tags.length %}
          <span class="component-entry-tags">{{ component.tags | join(', ') }}</span>
        {% endif %}
      </a>
    {% endfor %}
  </div>
</section>