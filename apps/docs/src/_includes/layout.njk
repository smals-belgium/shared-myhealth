<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>
      {% if title %}
        {{ title }} –
      {% endif %}Design Kit Docs</title>
    <link rel="stylesheet" href="/styles/docs.css"/>
    <link rel="stylesheet" href="/assets/design-kit/my-health.css"/>
    <script type="module" src="/assets/design-kit/index.js"></script>
    <script defer src="/scripts/docs-controls.js"></script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="app-shell">
      <aside class="sidebar">
        <div class="sidebar-brand">
          <a href="/" aria-label="Design Kit Docs home">
            <span class="sidebar-brand-name">Design Kit</span>
            <span class="sidebar-brand-version">design-kit.version</span>
          </a>
        </div>
        <nav aria-label="Documentation">
          <div class="nav-group">
            <a href="/" class="nav-item{% if page.url === '/' %} is-active{% endif %}">Introduction</a>
          </div>
          <div class="nav-group">
            <span class="nav-group-label">Components</span>
            {% for component in components.components %}
              <a
                href="/components/{{ component.slug }}/"
                class="nav-item{% if page.url === '/components/' + component.slug + '/' %} is-active{% endif %}">
                {{ component.name }}
              </a>
            {% endfor %}
          </div>
          <div class="nav-group">
            <span class="nav-group-label">Tokens</span>
            <a href="/tokens/color/" class="nav-item{% if page.url === '/tokens/color/' %} is-active{% endif %}">
              Color
            </a>
          </div>
        </nav>
      </aside>
      <div class="main-panel">
        <main id="main-content" tabindex="-1" class="content">
          {{ content | safe }}
        </main>
      </div>
    </div>
  </body>
</html>