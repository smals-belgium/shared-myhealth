{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "tags": ["type:dk"],
  "targets": {
    "generate-icon-name": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/icon/icon-name.ts"],
      "options": {
        "command": "node tools/generate-icon-name.mjs",
        "cwd": "packages/design-kit"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["generate-icon-name", "^build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "vite build",
        "cwd": "packages/design-kit"
      }
    },
    "generate-manifest": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/custom-elements.json"],
      "options": {
        "command": "cem analyze",
        "cwd": "packages/design-kit"
      }
    },
    "bundle": {
      "dependsOn": ["build"],
      "command": "node tools/postcss.js"
    }
  }
}
