{
  "name": "vitals",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "tags": ["type:dk"],
  "targets": {
    "release": {
      "version": {
        "currentVersionResolver": "git-tag",
        "fallbackCurrentVersionResolver": "disk"
      }
    },
    "generate-icon-name": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/icon/icon-name.ts"],
      "options": {
        "command": "node tools/generate-icon-name.mjs",
        "cwd": "packages/design-kit"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["generate-icon-name", "^build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "vite build",
        "cwd": "packages/design-kit"
      }
    },
    "bundle": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "outputs": [
        "{projectRoot}/dist/custom-elements.json",
        "{projectRoot}/dist/my-health.css"
      ],
      "options": {
        "cwd": "packages/design-kit",
        "commands": ["cem analyze", "node ../../tools/postcss.js"]
      }
    }
  }
}
