{
  "name": "vitals-ng",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/vitals-ng/src",
  "prefix": "mh",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": ["{projectRoot}/dist"]
    }
  },
  "tags": ["type:dk"],
  "implicitDependencies": ["vitals"],
  "targets": {
    "prepare-package-json": {
      "command": "cp {projectRoot}/package.json {projectRoot}/src/package.json"
    },
    "build": {
      "executor": "@nx/angular:package",
      "dependsOn": ["^bundle", "prepare-package-json"],
      "outputs": ["{projectRoot}/dist"],
      "defaultConfiguration": "production",
      "options": {
        "project": "packages/vitals-ng/src/ng-package.json",
        "tsConfig": "packages/vitals-ng/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "packages/vitals-ng/tsconfig.lib.prod.json"
        },
        "development": {}
      }
    },
    "bundle": {
      "dependsOn": ["build"],
      "command": "cp LICENSE.md {projectRoot}/dist/LICENSE.md && cp {projectRoot}/*.md {projectRoot}/dist"
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "{projectRoot}/dist"
      }
    }
  }
}
