{
  "name": "vitals-ng",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/vitals-ng/src",
  "prefix": "mh",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": ["{projectRoot}/dist"]
    }
  },
  "tags": ["type:dk"],
  "implicitDependencies": ["vitals"],
  "targets": {
    "prepare-package-json": {
      "command": "node -e \"require('fs').copyFileSync('{projectRoot}/package.json', '{projectRoot}/src/package.json')\""
    },
    "build": {
      "executor": "@nx/angular:package",
      "dependsOn": ["^bundle", "prepare-package-json"],
      "outputs": ["{projectRoot}/dist"],
      "defaultConfiguration": "production",
      "options": {
        "project": "packages/vitals-ng/src/ng-package.json",
        "tsConfig": "packages/vitals-ng/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "packages/vitals-ng/tsconfig.lib.prod.json"
        },
        "development": {}
      }
    },
    "bundle": {
      "dependsOn": ["build"],
      "command": "node ../../tools/copy-dist-assets.mjs",
      "options": {
        "cwd": "packages/vitals-ng"
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "{projectRoot}/dist"
      }
    },
    "verify-package": {
      "executor": "nx:run-commands",
      "dependsOn": ["bundle"],
      "options": {
        "command": "node ../../tools/verify-package-integrity.mjs dist/LICENSE.md",
        "cwd": "packages/vitals-ng"
      }
    }
  }
}
