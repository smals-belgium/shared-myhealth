{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "sourceMap": true,
    "paths": {
      "@myhealth/design-kit": ["./packages/design-kit"]
    },
    "types": []
  },
  "include": ["**/*.ts"],
  "exclude": [
    "**/*.spec.ts",
