{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "sourceMap": true,
    "paths": {
      "@myhealth/design-kit": ["./packages/design-kit/dist"]
    },
    "types": []
  },
  "include": [
    "src/**/*.ts",
    "button/src/**/*.ts",
    "checkbox/src/**/*.ts",
    "radio/src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx",
    "src/test-setup.ts",
    "button/src/**/*.spec.ts",
    "checkbox/src/**/*.spec.ts",
    "radio/src/**/*.spec.ts"
  ]
}
