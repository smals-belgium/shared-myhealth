{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "types": ["vitest/globals", "node", "vite/client"],
    "experimentalDecorators": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "useDefineForClassFields": false
  },
  "include": ["src/**/*.spec.ts", "src/**/*.test.ts"],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}
