{
  "name": "@myhealth-belgium/vitals",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "targets": {
      "generate-manifest": {
        "executor": "nx:run-commands",
        "inputs": [
          "{projectRoot}/src/**/*.ts",
          "!{projectRoot}/src/**/*.spec.ts"
        ],
        "outputs": [
          "{projectRoot}/custom-elements.json"
        ],
        "options": {
          "command": "npx cem analyze",
          "cwd": "packages/vitals/components"
        }
      }
    }
  },
  "dependencies": {
    "@vitals/core": "0.0.1",
    "@vitals/tokens": "0.0.1",
    "lit": "^3.3.2"
  },
  "customElements": "custom-elements.json"
}
