{
  "name": "@vitals/core",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@vitals/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./event": {
      "@vitals/source": "./src/event/index.ts",
      "types": "./dist/event/index.d.ts",
      "import": "./dist/event/index.js",
      "default": "./dist/event/index.js"
    },
    "./i18n": {
      "@vitals/source": "./src/i18n/index.ts",
      "types": "./dist/i18n/index.d.ts",
      "import": "./dist/i18n/index.js",
      "default": "./dist/i18n/index.js"
    },
    "./testing": {
      "@vitals/source": "./src/testing/index.ts",
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "default": "./dist/testing/index.js"
    },
    "./*.css": {
      "@vitals/source": "./src/*.css",
      "default": "./dist/*.css"
    }
  },
  "dependencies": {
    "lit": "^3.3.2"
  }
}
